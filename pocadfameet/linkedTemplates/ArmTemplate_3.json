				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "mumbaisourceunionconn",
								"type": "DatasetReference"
							},
							"name": "Mumbaisource1"
						},
						{
							"dataset": {
								"referenceName": "Delhisourceunionconn",
								"type": "DatasetReference"
							},
							"name": "Delhisource2"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "mumbaiuniondelhioutput",
								"type": "DatasetReference"
							},
							"name": "mumbaiuniondelhioutput"
						}
					],
					"transformations": [
						{
							"name": "mumbaiuniondelhi"
						}
					],
					"scriptLines": [
						"source(output(",
						"          Month as string,",
						"          Sales as string,",
						"          Profit as string,",
						"          Location as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> Mumbaisource1",
						"source(output(",
						"          Month as string,",
						"          Sales as string,",
						"          Profit as string,",
						"          Location as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> Delhisource2",
						"Mumbaisource1, Delhisource2 union(byName: true)~> mumbaiuniondelhi",
						"mumbaiuniondelhi sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     input(",
						"          CustomerID as string,",
						"          NameStyle as string,",
						"          Title as string,",
						"          FirstName as string,",
						"          MiddleName as string,",
						"          LastName as string,",
						"          Suffix as string,",
						"          CompanyName as string,",
						"          SalesPerson as string,",
						"          EmailAddress as string,",
						"          Phone as string,",
						"          PasswordHash as string,",
						"          PasswordSalt as string,",
						"          rowguid as string,",
						"          ModifiedDate as string",
						"     ),",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> mumbaiuniondelhioutput"
					]
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/Select_Transformation')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "sourcefiledatalake1",
								"type": "DatasetReference"
							},
							"name": "sourcedatafile"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "selectoutputfile",
								"type": "DatasetReference"
							},
							"name": "outputcontainer"
						}
					],
					"transformations": [
						{
							"name": "selecttransformation"
						}
					],
					"scriptLines": [
						"source(output(",
						"          Retailer as string,",
						"          {Retailer ID} as string,",
						"          {Invoice Date} as string,",
						"          Region as string,",
						"          State as string,",
						"          City as string,",
						"          Product as string,",
						"          {Price per Unit} as string,",
						"          {Units Sold} as string,",
						"          {Total Sales} as string,",
						"          {Operating Profit} as string,",
						"          {Operating Margin} as string,",
						"          {Sales Method} as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> sourcedatafile",
						"sourcedatafile select(mapColumn(",
						"          Retailer,",
						"          Retailer_ID = {Retailer ID},",
						"          Invoice_Date = {Invoice Date},",
						"          Region,",
						"          State,",
						"          City,",
						"          Product_Desc = Product,",
						"          Price_per_Unit = {Price per Unit},",
						"          Units_Sold = {Units Sold},",
						"          Total_Sales = {Total Sales},",
						"          Operating_Profit = {Operating Profit}",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> selecttransformation",
						"selecttransformation sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> outputcontainer"
					]
				}
			},
			"dependsOn": []
		},
